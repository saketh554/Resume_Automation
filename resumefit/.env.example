# Copy this file to .env and fill in your values. Never commit .env.

# OpenAI API key — used by the analysis (gpt-4o) and parsing (gpt-4o-mini) nodes.
OPENAI_API_KEY=sk-your-key-here

# Models (swappable; no hard-coded model names in agent code).
MODEL_ANALYSIS=gpt-4o
MODEL_PARSING=gpt-4o-mini

# SQLite database path (file-backed so analyses survive restarts).
DATABASE_URL=sqlite:///./data/resumefit.db

# Where uploaded resumes and generated tailored .docx files are stored.
DATA_DIR=./data
